# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/storai
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:password@localhost:5432/storai

# JWT Secret
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
TELEGRAM_BOT_USERNAME=StorAIBot

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Environment
ENVIRONMENT=development
DEBUG=True

# Ecommerce
CURRENCY=USD
TAX_RATE=0.16
